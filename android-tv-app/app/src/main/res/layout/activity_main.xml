<?xml version="1.0" encoding="utf-8"?>
<!--
    Hotel TV — MainActivity Layout
    Architecture (layers, bottom to top):
      Layer 1 — PlayerView   : Hardware-accelerated video for UDP/HLS streams
      Layer 2 — WebView      : Transparent React UI overlay
      Layer 3 — Loading Overlay : Native spinner/error screen (sits on top of everything)
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!--
        ══ LAYER 1: Native ExoPlayer Video Surface ══
        - Placed first so it renders BEHIND the WebView
        - use_controller="false" hides all default ExoPlayer UI chrome
        - resize_mode="fill" ensures the video fills the entire screen
    -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        app:use_controller="false"
        app:resize_mode="fill"/>

    <!--
        ══ LAYER 2: WebView Transparent Overlay ══
        - Placed second so it renders ON TOP of the PlayerView
        - Background is set to Color.TRANSPARENT in Kotlin code
        - The React app controls visibility of its own opaque backgrounds
        - When playing Live TV: React sets its background to transparent,
          revealing the ExoPlayer video playing behind it
    -->
    <WebView
        android:id="@+id/web_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:layerType="software"/>

    <!--
        ══ LAYER 3: Native Loading / Error Overlay ══
        - Sits on top of everything — shown while the WebView is loading
          or if the network/server is unreachable.
        - Staff can see this screen instead of a black void.
        - The 5-click IP dialog still works while this overlay is visible.
        - Controlled entirely from Kotlin: VISIBLE → GONE on success,
          or switches to error message + auto-retry on failure.
    -->
    <LinearLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#FF050505"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:visibility="visible">

        <!-- Just a simple, subtle spinner while the WebView connects -->
        <ProgressBar
            android:id="@+id/loading_spinner"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminate="true"
            android:indeterminateTint="#66FFFFFF"/>

        <!-- Primary status title — Used for Error messages only -->
        <TextView
            android:id="@+id/loading_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:gravity="center"/>

        <!-- Secondary subtitle / error detail -->
        <TextView
            android:id="@+id/loading_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="48dp"
            android:text=""
            android:textColor="#AAFFFFFF"
            android:textSize="15sp"
            android:gravity="center"/>

        <!-- Server IP hint — completely hidden from guests, kept for internal reference -->
        <TextView
            android:id="@+id/loading_ip_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text=""
            android:textColor="#00000000"
            android:textSize="1sp"
            android:gravity="center"
            android:visibility="gone"/>

    </LinearLayout>

</FrameLayout>
