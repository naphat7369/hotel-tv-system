generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Hotel {
  id              String            @id @default(uuid()) 
  name            String            
  code            String            @unique 
  timezone        String?           
  locale          String?           
  settings        String?
  createdAt       DateTime          @default(now()) @map("created_at") 
  rooms           Room[]
  devices         Device[]
  channels        Channel[]
  streamingApps   StreamingApp[]
  screenTemplates ScreenTemplate[]
  reservations    Reservation[]
  usageEvents     UsageEvent[]
  guestRequests   GuestRequest[]
  savedMessages   SavedMessage[]
  activeBroadcasts ActiveBroadcast[]

  @@map("hotels")
}

model Room {
  id           String        @id @default(uuid()) 
  hotelId      String        @map("hotel_id") 
  roomNumber   String        @map("room_number") 
  floor        Int?
  roomType     String?       @map("room_type") 
  building     String?       
  isActive     Boolean       @default(true) @map("is_active")
  hotel        Hotel         @relation(fields: [hotelId], references: [id])
  devices      Device[]
  reservations  Reservation[]
  usageEvents   UsageEvent[]
  guestRequests GuestRequest[]

  @@map("rooms")
}

model Device {
  id               String          @id @default(uuid()) 
  hotelId          String          @map("hotel_id") 
  roomId           String?         @map("room_id") 
  boxSerial        String          @unique @map("box_serial") 
  macAddress       String?         @map("mac_address") 
  ipAddress        String?         @map("ip_address") 
  androidVersion   String?         @map("android_version") 
  appVersion       String?         @map("app_version") 
  isOnline         Boolean         @default(false) @map("is_online")
  lastSeen         DateTime?       @map("last_seen") 
  tvPowerState     String?         @map("tv_power_state") 
  currentApp       String?         @map("current_app") 
  currentChannel   Int?            @map("current_channel")
  registeredAt     DateTime        @default(now()) @map("registered_at") 
  hotel            Hotel           @relation(fields: [hotelId], references: [id])
  room             Room?           @relation(fields: [roomId], references: [id])
  usageEvents      UsageEvent[]
  deviceCommands   DeviceCommand[]

  @@map("devices")
}

model Channel {
  id             String   @id @default(uuid()) 
  hotelId        String   @map("hotel_id") 
  channelNumber  Int?     @map("channel_number")
  name           String   
  logoUrl        String?  @map("logo_url") 
  category       String?  
  streamUrl      String?  @map("stream_url") 
  streamType     String?  @map("stream_type") 
  epgId          String?  @map("epg_id") 
  isActive       Boolean  @default(true) @map("is_active")
  accessLevel    String   @default("all") @map("access_level") 
  parentalLock   Boolean  @default(false) @map("parental_lock")
  sortOrder      Int?     @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at") 
  updatedAt      DateTime @default(now()) @map("updated_at") 
  hotel          Hotel    @relation(fields: [hotelId], references: [id])

  @@map("channels")
}

model StreamingApp {
  id              String  @id @default(uuid()) 
  hotelId         String  @map("hotel_id") 
  name            String  
  packageName     String? @map("package_name") 
  iconUrl         String? @map("icon_url") 
  deepLink        String? @map("deep_link") 
  autoLogout      Boolean @default(true) @map("auto_logout")
  logoutCommand   String? @map("logout_command") 
  isActive        Boolean @default(true) @map("is_active")
  sortOrder       Int?    @map("sort_order")
  hotel           Hotel   @relation(fields: [hotelId], references: [id])

  @@map("streaming_apps")
}

model ScreenTemplate {
  id            String   @id @default(uuid()) 
  hotelId       String   @map("hotel_id") 
  name          String   
  screenType    String?  @map("screen_type") 
  templateData  String?    @map("template_data")
  backgroundUrl String?  @map("background_url") 
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") 
  updatedAt     DateTime @default(now()) @map("updated_at") 
  hotel         Hotel    @relation(fields: [hotelId], references: [id])

  @@map("screen_templates")
}

model Reservation {
  id                 String       @id @default(uuid()) 
  hotelId            String       @map("hotel_id") 
  roomId             String?      @map("room_id") 
  pmsReservationId   String?      @map("pms_reservation_id") 
  guestFirstName     String?      @map("guest_first_name") 
  guestLastName      String?      @map("guest_last_name") 
  guestLoyaltyTier   String?      @map("guest_loyalty_tier") 
  guestLoyaltyId     String?      @map("guest_loyalty_id") 
  guestLanguage      String?      @map("guest_language") 
  checkIn            DateTime?    @map("check_in") 
  checkOut           DateTime?    @map("check_out") 
  roomType           String?      @map("room_type") 
  status             String?      
  createdAt          DateTime     @default(now()) @map("created_at") 
  updatedAt          DateTime     @default(now()) @map("updated_at") 
  hotel              Hotel        @relation(fields: [hotelId], references: [id])
  room               Room?        @relation(fields: [roomId], references: [id])
  usageEvents        UsageEvent[]

  @@map("reservations")
}

model UsageEvent {
  id               String       @id @default(uuid()) 
  hotelId          String       @map("hotel_id") 
  roomId           String?      @map("room_id") 
  deviceId         String?      @map("device_id") 
  reservationId    String?      @map("reservation_id") 
  eventType        String?      @map("event_type") 
  value            String?      
  durationSeconds  Int?         @map("duration_seconds")
  guestType        String?      @map("guest_type") 
  timestamp        DateTime     @default(now()) 
  hotel            Hotel        @relation(fields: [hotelId], references: [id])
  room             Room?        @relation(fields: [roomId], references: [id])
  device           Device?      @relation(fields: [deviceId], references: [id])
  reservation      Reservation? @relation(fields: [reservationId], references: [id])

  @@map("usage_events")
}

model DeviceCommand {
  id          String    @id @default(uuid()) 
  deviceId    String?   @map("device_id") 
  commandType String?   @map("command_type") 
  payload     String?
  status      String?   
  sentAt      DateTime? @map("sent_at") 
  ackAt       DateTime? @map("ack_at") 
  createdBy   String?   @map("created_by") 
  createdAt   DateTime  @default(now()) @map("created_at") 
  device      Device?   @relation(fields: [deviceId], references: [id])

  @@map("device_commands")
}

model GuestRequest {
  id            String   @id @default(uuid()) 
  hotelId       String   @map("hotel_id") 
  roomId        String?  @map("room_id") 
  requestType   String   @map("request_type") 
  items         String
  status        String   @default("PENDING") 
  createdAt     DateTime @default(now()) @map("created_at") 
  updatedAt     DateTime @default(now()) @map("updated_at") 
  hotel         Hotel    @relation(fields: [hotelId], references: [id])
  room          Room?    @relation(fields: [roomId], references: [id])

  @@map("guest_requests")
}

model SavedMessage {
  id        String   @id @default(uuid())
  hotelId   String   @map("hotel_id")
  message   String
  type      String   @default("custom") 
  createdAt DateTime @default(now()) @map("created_at")
  hotel     Hotel    @relation(fields: [hotelId], references: [id])

  @@map("saved_messages")
}

model ActiveBroadcast {
  id           String    @id @default(uuid())
  hotelId      String    @map("hotel_id")
  message      String
  type         String    @default("default")
  target       String    @default("all")
  targetRoom   String?   @map("target_room")
  targetFloor  Int?      @map("target_floor")
  startTime    DateTime? @map("start_time")
  endTime      DateTime? @map("end_time")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  hotel        Hotel     @relation(fields: [hotelId], references: [id])

  @@map("active_broadcasts")
}
