generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hotel {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @db.VarChar(200)
  code            String           @unique @db.VarChar(20)
  timezone        String?          @db.VarChar(50)
  locale          String?          @db.VarChar(10)
  settings        Json?
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  rooms           Room[]
  devices         Device[]
  channels        Channel[]
  streamingApps   StreamingApp[]
  screenTemplates ScreenTemplate[]
  reservations    Reservation[]
  usageEvents     UsageEvent[]
  guestRequests   GuestRequest[]

  @@map("hotels")
}

model Room {
  id            String         @id @default(uuid()) @db.Uuid
  hotelId       String         @map("hotel_id") @db.Uuid
  roomNumber    String         @map("room_number") @db.VarChar(20)
  floor         Int?
  roomType      String?        @map("room_type") @db.VarChar(50)
  building      String?        @db.VarChar(50)
  isActive      Boolean        @default(true) @map("is_active")
  hotel         Hotel          @relation(fields: [hotelId], references: [id])
  devices       Device[]
  reservations  Reservation[]
  usageEvents   UsageEvent[]
  guestRequests GuestRequest[]

  @@map("rooms")
}

model Device {
  id             String          @id @default(uuid()) @db.Uuid
  hotelId        String          @map("hotel_id") @db.Uuid
  roomId         String?         @map("room_id") @db.Uuid
  boxSerial      String          @unique @map("box_serial") @db.VarChar(100)
  macAddress     String?         @map("mac_address") @db.VarChar(17)
  ipAddress      String?         @map("ip_address") @db.Inet
  androidVersion String?         @map("android_version") @db.VarChar(20)
  appVersion     String?         @map("app_version") @db.VarChar(20)
  isOnline       Boolean         @default(false) @map("is_online")
  lastSeen       DateTime?       @map("last_seen") @db.Timestamptz
  tvPowerState   String?         @map("tv_power_state") @db.VarChar(20)
  currentApp     String?         @map("current_app") @db.VarChar(100)
  currentChannel Int?            @map("current_channel")
  registeredAt   DateTime        @default(now()) @map("registered_at") @db.Timestamptz
  hotel          Hotel           @relation(fields: [hotelId], references: [id])
  room           Room?           @relation(fields: [roomId], references: [id])
  usageEvents    UsageEvent[]
  deviceCommands DeviceCommand[]

  @@map("devices")
}

model Channel {
  id            String   @id @default(uuid()) @db.Uuid
  hotelId       String   @map("hotel_id") @db.Uuid
  channelNumber Int?     @map("channel_number")
  name          String   @db.VarChar(100)
  logoUrl       String?  @map("logo_url") @db.Text
  category      String?  @db.VarChar(50)
  streamUrl     String?  @map("stream_url") @db.Text
  streamType    String?  @map("stream_type") @db.VarChar(20)
  epgId         String?  @map("epg_id") @db.VarChar(50)
  isActive      Boolean  @default(true) @map("is_active")
  accessLevel   String   @default("all") @map("access_level") @db.VarChar(20)
  parentalLock  Boolean  @default(false) @map("parental_lock")
  sortOrder     Int?     @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz
  hotel         Hotel    @relation(fields: [hotelId], references: [id])

  @@map("channels")
}

model StreamingApp {
  id            String  @id @default(uuid()) @db.Uuid
  hotelId       String  @map("hotel_id") @db.Uuid
  name          String  @db.VarChar(100)
  packageName   String? @map("package_name") @db.VarChar(200)
  iconUrl       String? @map("icon_url") @db.Text
  deepLink      String? @map("deep_link") @db.Text
  autoLogout    Boolean @default(true) @map("auto_logout")
  logoutCommand String? @map("logout_command") @db.Text
  isActive      Boolean @default(true) @map("is_active")
  sortOrder     Int?    @map("sort_order")
  hotel         Hotel   @relation(fields: [hotelId], references: [id])

  @@map("streaming_apps")
}

model ScreenTemplate {
  id            String   @id @default(uuid()) @db.Uuid
  hotelId       String   @map("hotel_id") @db.Uuid
  name          String   @db.VarChar(100)
  screenType    String?  @map("screen_type") @db.VarChar(50)
  templateData  Json?    @map("template_data")
  backgroundUrl String?  @map("background_url") @db.Text
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz
  hotel         Hotel    @relation(fields: [hotelId], references: [id])

  @@map("screen_templates")
}

model Reservation {
  id               String       @id @default(uuid()) @db.Uuid
  hotelId          String       @map("hotel_id") @db.Uuid
  roomId           String?      @map("room_id") @db.Uuid
  pmsReservationId String?      @map("pms_reservation_id") @db.VarChar(100)
  guestFirstName   String?      @map("guest_first_name") @db.VarChar(100)
  guestLastName    String?      @map("guest_last_name") @db.VarChar(100)
  guestLoyaltyTier String?      @map("guest_loyalty_tier") @db.VarChar(20)
  guestLoyaltyId   String?      @map("guest_loyalty_id") @db.VarChar(50)
  guestLanguage    String?      @map("guest_language") @db.VarChar(10)
  checkIn          DateTime?    @map("check_in") @db.Date
  checkOut         DateTime?    @map("check_out") @db.Date
  roomType         String?      @map("room_type") @db.VarChar(50)
  status           String?      @db.VarChar(20)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime     @default(now()) @map("updated_at") @db.Timestamptz
  hotel            Hotel        @relation(fields: [hotelId], references: [id])
  room             Room?        @relation(fields: [roomId], references: [id])
  usageEvents      UsageEvent[]

  @@map("reservations")
}

model UsageEvent {
  id              String       @id @default(uuid()) @db.Uuid
  hotelId         String       @map("hotel_id") @db.Uuid
  roomId          String?      @map("room_id") @db.Uuid
  deviceId        String?      @map("device_id") @db.Uuid
  reservationId   String?      @map("reservation_id") @db.Uuid
  eventType       String?      @map("event_type") @db.VarChar(50)
  value           String?      @db.VarChar(200)
  durationSeconds Int?         @map("duration_seconds")
  guestType       String?      @map("guest_type") @db.VarChar(20)
  timestamp       DateTime     @default(now()) @db.Timestamptz
  hotel           Hotel        @relation(fields: [hotelId], references: [id])
  room            Room?        @relation(fields: [roomId], references: [id])
  device          Device?      @relation(fields: [deviceId], references: [id])
  reservation     Reservation? @relation(fields: [reservationId], references: [id])

  @@map("usage_events")
}

model DeviceCommand {
  id          String    @id @default(uuid()) @db.Uuid
  deviceId    String?   @map("device_id") @db.Uuid
  commandType String?   @map("command_type") @db.VarChar(50)
  payload     Json?
  status      String?   @db.VarChar(20)
  sentAt      DateTime? @map("sent_at") @db.Timestamptz
  ackAt       DateTime? @map("ack_at") @db.Timestamptz
  createdBy   String?   @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  device      Device?   @relation(fields: [deviceId], references: [id])

  @@map("device_commands")
}

model GuestRequest {
  id          String   @id @default(uuid()) @db.Uuid
  hotelId     String   @map("hotel_id") @db.Uuid
  roomId      String?  @map("room_id") @db.Uuid
  requestType String   @map("request_type") @db.VarChar(50)
  items       Json
  status      String   @default("PENDING") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz
  hotel       Hotel    @relation(fields: [hotelId], references: [id])
  room        Room?    @relation(fields: [roomId], references: [id])

  @@map("guest_requests")
}
