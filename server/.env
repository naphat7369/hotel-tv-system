# Server
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:pass@localhost:5432/hotel_tv
REDIS_URL=redis://localhost:6379
JWT_SECRET=super_secret_jwt_key_12345
JWT_EXPIRES_IN=8h

# Media
CDN_BASE_URL=https://cdn.hotel.internal
S3_BUCKET=hotel-tv-media
S3_REGION=ap-southeast-1

# PMS
PMS_WEBHOOK_SECRET=hmac_secret_here
PMS_API_URL=https://pms.hotel.com/api
PMS_API_KEY=pms_api_key_here

# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=hoteltvserver
MQTT_PASSWORD=mqtt_password_here

# Android Box
ADB_HOST_WHITELIST=10.10.1.0/24
DEVICE_API_KEY_SALT=salt_for_device_key
ADB_PATH=C:\Users\DESKTOP-S31-IT\AppData\Local\Android\Sdk\platform-tools\adb.exe
